# ============================================
# 腾讯云函数 (SCF) 环境变量配置
# ============================================
# 在腾讯云函数控制台 → 函数配置 → 环境变量 中设置以下值

# 企业微信企业ID（在管理后台「我的企业」→「企业信息」底部查看）
WECOM_CORP_ID=your_corp_id_here

# 企业微信自建应用「秘书Jack」的配置
WECOM_AGENT_ID=1000002
WECOM_CORP_SECRET=your_corp_secret_here

# API接收消息页面生成的 Token 和 EncodingAESKey
WECOM_TOKEN=tCUTt6eGvU2g1jyfANmelcafsry
WECOM_ENCODING_AES_KEY=DT69uLANA5eed9ZY3fal3zeTjpZaLWLp75IyOAQ5IMc

# 群机器人 Webhook URL（用于发送反馈到群里）
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_NEW_KEY_HERE
