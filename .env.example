# ===========================================
# YuePaoQuan Coach — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Database (MongoDB / Tencent CloudBase) ---
DATABASE_URL=mongodb://localhost:27017
DATABASE_NAME=yuepaoquan_db
COLLECTION_NAME=activities

# --- WeCom (企业微信) ---
# Create a Webhook bot in your WeCom group chat, paste the full URL here
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY_HERE

# --- AI / LLM ---
API_KEY=
