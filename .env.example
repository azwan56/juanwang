# ===========================================
# YuePaoQuan WeCom 机器人 — 环境变量配置
# 复制此文件并填入真实值：
#   cp .env.example .env
# ===========================================

# ─── 企业微信应用配置（必填）───────────────────
# 「我的企业」→ 企业信息 → 最底部
WECOM_CORP_ID=

# 「秘书Jack」应用 → 功能 → 接收消息 → API接收 → Token
WECOM_TOKEN=tCUTt6eGvU2g1jyfANmelcafsry

# 「秘书Jack」应用 → 功能 → 接收消息 → API接收 → EncodingAESKey
WECOM_ENCODING_AES_KEY=DT69uLANA5eed9ZY3fal3zeTjpZaLWLp75IyOAQ5IMc

# 「秘书Jack」应用 → 基本信息 → Secret（点「查看」获取）
WECOM_CORP_SECRET=

# 「秘书Jack」应用 → 基本信息 → AgentId
WECOM_AGENT_ID=1000002

# ─── AI 视觉 OCR 配置（必填，用于解析跑步截图）──
# 智谱平台 https://open.bigmodel.cn → 控制台 → API密钥
AI_API_KEY=

# AI API 地址（默认智谱，无需修改）
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 使用的模型（支持图片输入的多模态模型）
AI_MODEL=glm-4v-plus

# ─── 服务器配置（可选）──────────────────────────
# 本地监听端口（SCF 中继会转发到此端口）
PORT=8645

# ─── 旧版 Webhook 机器人（可选，用于群消息广播）─
# WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY_HERE
